# Database (asyncpg format)
DATABASE_URL=postgresql+asyncpg://ghost:ghost@localhost:5432/ghost

# OpenAI (required for the security analysis agent)
OPENAI_API_KEY=sk-...

# GitHub Personal Access Token (recommended — 5000 req/hr vs 60 unauthenticated)
GITHUB_TOKEN=ghp_...

# Slack Incoming Webhook (optional — for alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Admin API Key (optional — protects the /webhooks/poll endpoint)
ADMIN_API_KEY=

# Polling intervals in seconds (how often each priority tier is checked)
POLL_INTERVAL_CRITICAL=60
POLL_INTERVAL_HIGH=120
POLL_INTERVAL_MEDIUM=300
POLL_INTERVAL_LOW=900

# Frontend URL (used in Slack alert links)
FRONTEND_URL=http://localhost:3000

# CORS (comma-separated origins allowed to call the API)
ALLOWED_ORIGINS=http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8000
