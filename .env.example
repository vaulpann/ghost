# Database
DATABASE_URL=postgresql+asyncpg://ghost:ghost@localhost:5432/ghost

# OpenAI
OPENAI_API_KEY=sk-...

# GitHub (for higher rate limits on GitHub API)
GITHUB_TOKEN=ghp_...

# Alerting
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Polling intervals (seconds)
POLL_INTERVAL_CRITICAL=60
POLL_INTERVAL_HIGH=120
POLL_INTERVAL_MEDIUM=300
POLL_INTERVAL_LOW=900

# Analysis
TRIAGE_MODEL=gpt-4o-mini
DEEP_ANALYSIS_MODEL=gpt-4o
SYNTHESIS_MODEL=gpt-4o

# Frontend URL (for links in alerts)
FRONTEND_URL=http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8000
